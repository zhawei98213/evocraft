{
  "name": "evocraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "electron:dev": "wait-on http://127.0.0.1:5173 && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "desktop:dev": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "desktop:build": "npm run build && electron-builder --dir",
    "desktop:open": "npm run desktop:build && open -n release/mac/EvoCraft.app",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node tests/static-mvp.test.mjs && node tests/logo-assets.test.mjs && node tests/ai-eval-config.test.mjs && node tests/ai-eval-summary.test.mjs && vitest run",
    "test:ai-eval-config": "node tests/ai-eval-config.test.mjs",
    "test:ai-eval-summary": "node tests/ai-eval-summary.test.mjs",
    "test:electron-config": "node tests/electron-config.test.mjs && node tests/electron-ai-ipc.test.mjs && node tests/electron-file-ipc.test.mjs",
    "test:electron-store": "node tests/electron-local-record-store.test.mjs",
    "test:qwen-adapter": "node tests/qwen-adapter-contract.test.mjs",
    "test:static": "node tests/static-mvp.test.mjs",
    "test:react": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.evocraft.app",
    "productName": "EvoCraft",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "build-resources/icon.icns",
      "identity": null
    }
  }
}
